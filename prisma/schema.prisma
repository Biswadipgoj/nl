// NanoLink — Prisma Schema
// Provider: PostgreSQL (Supabase)
// NOTE: Connection URLs are configured in prisma.config.ts (Prisma v7 convention)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Link {
  id          String    @id @default(cuid())
  userId      String?
  originalUrl String
  shortCode   String    @unique
  customAlias String?   @unique
  password    String?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  oneTimeUse  Boolean   @default(false)
  clicks      Int       @default(0)
  lastVisited DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shortCode])
  @@index([userId])
  @@index([customAlias])
  @@index([createdAt])
}
